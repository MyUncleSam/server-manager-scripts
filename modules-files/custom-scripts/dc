#!/bin/bash

# Detect compose runtime: prefer docker, fall back to podman.
detect_compose() {
    if command -v docker &>/dev/null && docker compose version &>/dev/null; then
        echo "docker compose"
    elif command -v podman &>/dev/null && podman compose version &>/dev/null; then
        echo "podman compose"
    elif command -v podman-compose &>/dev/null; then
        echo "podman-compose"
    else
        return 1
    fi
}

COMPOSE=$(detect_compose) || {
    echo "Error: no compose runtime found (need 'docker compose', 'podman compose', or 'podman-compose')." >&2
    exit 1
}

# Color codes (only enable on a TTY to keep logs/pipes clean)
if [ -t 1 ]; then
    C_RESET=$'\033[0m'
    C_LABEL=$'\033[1;97;44m'   # bold white on blue
    C_CMD=$'\033[1;33m'        # bold yellow
else
    C_RESET=''
    C_LABEL=''
    C_CMD=''
fi

# Print a highly visible "Executing:" banner for the given command string.
announce() {
    printf '%s Executing %s %s%s%s\n' "$C_LABEL" "$C_RESET" "$C_CMD" "$*" "$C_RESET"
}

# Define a usage function
usage() {
    echo "Usage: dc [options]"
    echo "Runtime: $COMPOSE"
    echo "Options:"
    echo "  d - $COMPOSE down"
    echo "  e - $COMPOSE exec [container_name] [command]"
    echo "  k - $COMPOSE kill"
    echo "  l - $COMPOSE logs -f --tail=1000"
    echo "  p - $COMPOSE pull"
    echo "  ps - $COMPOSE ps"
    echo "  r - $COMPOSE restart"
    echo "  t - $COMPOSE top"
    echo "  u - $COMPOSE up -d"
    echo "  v - $COMPOSE volumes"
}

# Check if the correct number of arguments is provided
if [ "$#" -lt 1 ]; then
    usage
    exit 1
fi

# Iterate over each character in the input string
input_string="$1"
for (( i=0; i<${#input_string}; i++ )); do
    char="${input_string:$i:1}"
    case $char in
        d) announce "$COMPOSE down" && $COMPOSE down ;;
        e) announce "$COMPOSE exec ${*:2}" && $COMPOSE exec "${@:2}" ;;
        k) announce "$COMPOSE kill" && $COMPOSE kill ;;
        l) announce "$COMPOSE logs -f --tail=1000" && $COMPOSE logs -f --tail=1000 ;;
        p)
            # Check if next character is 's' for "ps"
            next_char="${input_string:$((i+1)):1}"
            if [ "$next_char" = "s" ]; then
                announce "$COMPOSE ps" && $COMPOSE ps
                ((i++))  # skip the 's'
            else
                announce "$COMPOSE pull" && $COMPOSE pull
            fi
            ;;
        r) announce "$COMPOSE restart" && $COMPOSE restart ;;
        t) announce "$COMPOSE top" && $COMPOSE top ;;
        u) announce "$COMPOSE up -d" && $COMPOSE up -d ;;
        v) announce "$COMPOSE volumes" && $COMPOSE volumes ;;
        *) echo "Unknown option: $char" >&2; usage; exit 1 ;;
    esac
done
